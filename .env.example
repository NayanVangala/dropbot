# ============================================
# AI Dropshipping Bot — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Shopify ---
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01

# --- Discord ---
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_GUILD_ID=your-discord-guild-id
DISCORD_CHANNEL_ID=your-report-channel-id

# --- LLM Provider ---
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# OLLAMA_BASE_URL=http://localhost:11434

# --- PicoClaw ---
PICOCLAW_ENABLED=true
PICOCLAW_CONFIG_PATH=~/.picoclaw/config.json

# --- Supplier ---
SUPPLIER_PLATFORM=aliexpress
# CJ_API_KEY=your-cj-api-key
# SPOCKET_API_KEY=your-spocket-api-key

# --- App Settings ---
DATABASE_PATH=./data/dropbot.db
LOG_LEVEL=INFO
API_PORT=3001
DASHBOARD_PORT=5173

# --- Scraper Settings ---
MIN_PROFIT_MARGIN=0.30
MAX_SHIPPING_DAYS=15
MIN_REVIEW_SCORE=4.0
MIN_REVIEW_COUNT=50
MAX_COMPETITOR_COUNT=20
SCRAPE_INTERVAL_HOURS=6

# --- Price Monitor ---
PRICE_CHECK_INTERVAL_MINUTES=15
MIN_MARGIN_THRESHOLD=0.20

# --- Ngrok (optional, for remote access) ---
# NGROK_AUTH_TOKEN=your-ngrok-token
# NGROK_DOMAIN=your-domain.ngrok-free.app
