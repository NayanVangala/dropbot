{
  "name": "dropbot-typescript",
  "version": "1.0.0",
  "description": "AI Dropshipping Bot — TypeScript layer (Shopify, Discord, API, Dashboard)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/api.ts",
    "start": "tsx src/api.ts",
    "discord": "tsx src/discord.ts",
    "build": "tsc",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build"
  },
  "dependencies": {
    "@shopify/admin-api-client": "^1.0.0",
    "cors": "^2.8.5",
    "discord.js": "^14.14.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
